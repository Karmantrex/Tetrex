# 1️⃣ Download Miniconda installer for Mac (Intel)
curl -o miniconda.sh https://repo.anaconda.com/miniconda/Miniconda3-latest-MacOSX-x86_64.sh

# 2️⃣ Run the Miniconda installer
bash miniconda.sh

# 3️⃣ Activate Miniconda
source ~/miniconda3/bin/activate

# 4️⃣ Initialize Conda for Zsh (Mac default shell)
conda init zsh

# 5️⃣ Restart your terminal, then check Conda version
conda --version

# 6️⃣ Verify where Conda is installed
which conda

# 7️⃣ Check Conda environments
conda info --envs

# 8️⃣ Create a new test Conda environment with Python 3.9
conda create --name test_env python=3.9

# 9️⃣ Activate the new environment
conda activate test_env

# 🔟 Install a test package (numpy)
conda install numpy
