#!/bin/bash

if [ ! -f "$1" ]; then
  echo "Usage: $0 path_list_file.txt"
  exit 1
fi

echo "Starting cleanup using: $1"

while IFS= read -r raw_path || [[ -n "$raw_path" ]]; do
  # Skip empty lines
  [[ -z "$raw_path" ]] && continue

  # Auto-quote paths with spaces
  quoted_path=$(printf "%q" "$raw_path")

  # Expand things like $HOME and tilde (~)
  eval expanded_path="$quoted_path"

  # Skip if it's the script itself or the path file
  script_name="$(basename "$0")"
  path_file_name="$(basename "$1")"
  base_expanded="$(basename "$expanded_path")"

  if [[ "$base_expanded" == "$script_name" || "$base_expanded" == "$path_file_name" ]]; then
    echo "Skipping self: $expanded_path"
    continue
  fi

  if [ -e "$expanded_path" ]; then
    echo "Deleting: $expanded_path"
    sudo rm -rf "$expanded_path"
  else
    echo "Not found: $expanded_path"
  fi
done < "$1"

echo "✅ Done. No more FocusMe leftovers — hopefully for good!"
