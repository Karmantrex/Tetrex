function compareTwoColumnsForDuplicates() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  
  var firstColumnName = Browser.inputBox("Enter the first column name:");
  var secondColumnName = Browser.inputBox("Enter the second column name:");
  
  var firstColumnIndex = headers.indexOf(firstColumnName);
  var secondColumnIndex = headers.indexOf(secondColumnName);
  
  if (firstColumnIndex === -1 || secondColumnIndex === -1) {
    Browser.msgBox("One or both column names not found. Exiting script.");
    return;
  }
  
  var duplicates = [];
  
  for (var i = 1; i < data.length; i++) { // Skip header row
    for (var j = i + 1; j < data.length; j++) {
      if (data[i][firstColumnIndex] === data[j][secondColumnIndex]) {
        duplicates.push(data[i]);
        duplicates.push(data[j]);
      }
    }
  }
  
  if (duplicates.length > 0) {
    moveDuplicatesToNewSheet(headers, duplicates);
    Browser.msgBox("Matching rows copied to 'Duplicate_rows' sheet.");
  } else {
    Browser.msgBox("No matching rows found.");
  }
}

function moveDuplicatesToNewSheet(headers, duplicateRows) {
  var spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = spreadsheet.getSheetByName("Duplicate_rows");
  
  if (sheet) {
    spreadsheet.deleteSheet(sheet);
  }
  
  sheet = spreadsheet.insertSheet("Duplicate_rows");
  sheet.appendRow(headers);
  
  if (duplicateRows.length > 0) {
    sheet.getRange(2, 1, duplicateRows.length, duplicateRows[0].length).setValues(duplicateRows);
  }
}
