function findDuplicateRowsByColumns() {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  var data = sheet.getDataRange().getValues();
  var headers = data[0];
  var selectedColumns = [];
  
  while (true) {
    var columnName = Browser.inputBox("Enter column name to check for duplicates or type 'finish' to proceed:");
    if (columnName.toLowerCase() === 'finish') {
      break;
    }
    var colIndex = headers.indexOf(columnName);
    if (colIndex === -1) {
      Browser.msgBox("Column not found: " + columnName);
    } else {
      selectedColumns.push(colIndex);
    }
  }
  
  if (selectedColumns.length === 0) {
    Browser.msgBox("No columns selected. Exiting script.");
    return;
  }
  
  var duplicates = new Set();
  var duplicateRows = [];
  
  for (var i = 1; i < data.length; i++) { // Skip header row
    var rowKey = selectedColumns.map(idx => data[i][idx]).join('|');
    for (var j = i + 1; j < data.length; j++) {
      if (rowKey === selectedColumns.map(idx => data[j][idx]).join('|')) {
        duplicates.add(i);
        duplicates.add(j);
        duplicateRows.push(data[i]);
      }
    }
  }
  
  if (duplicates.size > 0) {
    moveDuplicatesToNewSheet(headers, duplicateRows);
    Browser.msgBox("Duplicate rows copied to 'Duplicate_rows' sheet.");
  } else {
    Browser.msgBox("No duplicate rows found.");
  }
}

function moveDuplicatesToNewSheet(headers, duplicateRows) {
  var spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = spreadsheet.getSheetByName("Duplicate_rows");
  
  if (sheet) {
    spreadsheet.deleteSheet(sheet);
  }
  
  sheet = spreadsheet.insertSheet("Duplicate_rows");
  sheet.appendRow(headers);
  
  if (duplicateRows.length > 0) {
    sheet.getRange(2, 1, duplicateRows.length, duplicateRows[0].length).setValues(duplicateRows);
  }
}
