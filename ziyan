#!/bin/bash

if [ ! -f "$1" ]; then
  echo "Usage: $0 path_list_file.txt"
  exit 1
fi

echo "Starting cleanup from file: $1"

while IFS= read -r line || [[ -n "$line" ]]; do
  # Expand variables like $HOME manually
  eval expanded_path="$line"

  if [ -e "$expanded_path" ]; then
    echo "Deleting: $expanded_path"
    sudo rm -rf "$expanded_path"
  else
    echo "Not found: $expanded_path"
  fi
done < "$1"

echo "Done. FocusMe traces should be gone."
