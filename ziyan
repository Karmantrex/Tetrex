# Temporarily disable script and watchdog
launchctl unload ~/Library/LaunchAgents/com.user.focusmonitor.plist 2>/dev/null
launchctl unload ~/Library/LaunchAgents/com.user.focuswatchdog.plist 2>/dev/null

# Remove files (you'll re-add fresh ones)
sudo chflags nouchg ~/.focus_monitor.sh ~/.focus_script_pass.enc ~/.focus_watchdog.sh 2>/dev/null
sudo chflags nouchg ~/.local/.focus_backup/* 2>/dev/null
sudo chflags nouchg ~/Library/LaunchAgents/com.user.focusmonitor.plist ~/Library/LaunchAgents/com.user.focuswatchdog.plist 2>/dev/null

rm -f ~/.focus_monitor.sh ~/.focus_script_pass.enc ~/.focus_watchdog.sh
rm -f ~/Library/LaunchAgents/com.user.focusmonitor.plist ~/Library/LaunchAgents/com.user.focuswatchdog.plist
rm -rf ~/.local/.focus_backup



vi ~/.focus_monitor.sh
chmod +x ~/.focus_monitor.sh
~/.focus_monitor.sh
~/.focus_monitor.sh lock
