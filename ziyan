#!/bin/bash

if [ ! -f "$1" ]; then
  echo "Usage: $0 path_list_file.txt"
  exit 1
fi

echo "Starting cleanup using: $1"

while IFS= read -r line || [[ -n "$line" ]]; do
  # Expand $HOME and other variables
  eval expanded_path="$line"

  # Skip if the file is the script itself or the path list
  script_name="$(basename "$0")"
  path_list_name="$(basename "$1")"
  base_path="$(basename "$expanded_path")"

  if [[ "$base_path" == "$script_name" || "$base_path" == "$path_list_name" ]]; then
    echo "Skipping self: $expanded_path"
    continue
  fi

  if [ -e "$expanded_path" ]; then
    echo "Deleting: $expanded_path"
    sudo rm -rf "$expanded_path"
  else
    echo "Not found: $expanded_path"
  fi
done < "$1"

echo "✅ Done. FocusMe junk should now be gone."
