#!/bin/bash
# Enhanced Focus Monitoring Script with Watchdog and Backup Failsafe for macOS

set -euo pipefail

# Configuration
readonly APP_NAME="Focus"
readonly EXCLUDED_APP="zoom.us"
readonly HOME_DIR="${HOME:-$HOME}"
readonly PASSWORD_FILE="${HOME_DIR}/.focus_script_pass.enc"
readonly SCRIPT_PATH="${HOME_DIR}/.focus_monitor.sh"
readonly LAUNCH_AGENT_PLIST="${HOME_DIR}/Library/LaunchAgents/com.user.focusmonitor.plist"
readonly BACKUP_DIR="${HOME_DIR}/.local/.focus_backup"
readonly MIN_PASSWORD_LENGTH=12
readonly LOG_FILE="${HOME_DIR}/.focus_monitor.log"
readonly MAX_LOG_SIZE=$((5 * 1024 * 1024)) # 5 MB

# Prompt for password if someone tries to view the script
if [[ "$0" == "$SCRIPT_PATH" && -z "${1:-}" ]]; then
  echo -n "Enter password to execute: "
  read -s pw
  echo
  if ! echo "$pw" | openssl enc -aes-256-cbc -pbkdf2 -iter 10000 -salt -d -in "$PASSWORD_FILE" &>/dev/null; then
    echo "[SECURITY] Unauthorized access denied."
    exit 1
  fi
fi

# Logging function with rotation for macOS
log_message() {
    local level="$1"
    local message="$2"
    local timestamp
    timestamp=$(date "+%Y-%m-%d %H:%M:%S")

    if [[ -f "$LOG_FILE" ]]; then
        local log_size
        log_size=$(stat -f "%z" "$LOG_FILE")
        if [[ "$log_size" -ge "$MAX_LOG_SIZE" ]]; then
            mv "$LOG_FILE" "${LOG_FILE}.1"
            gzip -f "${LOG_FILE}.1"
        fi
    fi

    echo "[${timestamp}] [${level}] ${message}" >> "$LOG_FILE"
    echo "[${level}] ${message}" >&2
}

validate_system() {
    for cmd in openssl osascript pgrep stat gzip; do
        if ! command -v "$cmd" &> /dev/null; then
            log_message "CRITICAL" "Required command $cmd not found."
            exit 1
        fi
    done

    if [[ "$(uname -s)" != "Darwin" ]]; then
        log_message "CRITICAL" "This script is only compatible with macOS."
        exit 1
    fi
}

validate_password() {
    local password="$1"
    local length=${#password}

    if [[ "$length" -lt "$MIN_PASSWORD_LENGTH" ]]; then
        log_message "ERROR" "Password too short. Minimum ${MIN_PASSWORD_LENGTH} characters required."
        return 1
    fi

    if ! [[ "$password" =~ [A-Z] ]] || \
       ! [[ "$password" =~ [a-z] ]] || \
       ! [[ "$password" =~ [0-9] ]] || \
       ! [[ "$password" =~ [\!\@\#\$\%\^\&\*\(\)_\+] ]]; then
        log_message "ERROR" "Password must contain uppercase, lowercase, number, and special character."
        return 1
    fi

    return 0
}

setup_password() {
    local password=""
    local attempts=3

    while [[ $attempts -gt 0 ]]; do
        read -sp "Set a secure password (min ${MIN_PASSWORD_LENGTH} chars): " password
        echo

        if validate_password "$password"; then
            echo "$password" | openssl enc -aes-256-cbc -pbkdf2 -iter 10000 -salt -out "$PASSWORD_FILE"
            chmod 600 "$PASSWORD_FILE"
            log_message "INFO" "Password saved securely."
            return 0
        fi

        attempts=$((attempts - 1))
        echo "Invalid password. $attempts attempts remaining."
    done

    log_message "CRITICAL" "Password setup failed after 3 attempts."
    exit 1
}

prompt_password() {
    local user_pass=""
    local decrypted_pass=""
    local attempts=3

    while [[ $attempts -gt 0 ]]; do
        read -sp "Enter password: " user_pass
        echo

        if decrypted_pass=$(echo "$user_pass" | openssl enc -aes-256-cbc -pbkdf2 -iter 10000 -salt -d -in "$PASSWORD_FILE" 2>/dev/null); then
            return 0
        fi

        attempts=$((attempts - 1))
        echo "Incorrect password. $attempts attempts remaining."
    done

    log_message "CRITICAL" "Action aborted due to multiple incorrect password attempts."
    exit 1
}

stop_monitor() {
    prompt_password
    launchctl unload "$LAUNCH_AGENT_PLIST" &>/dev/null
    log_message "INFO" "Focus Monitor temporarily stopped."
    exit 0
}

start_monitor() {
    prompt_password
    launchctl load "$LAUNCH_AGENT_PLIST" &>/dev/null
    log_message "INFO" "Focus Monitor manually started."
    exit 0
}

verify_password() {
    prompt_password
    sudo chflags nouchg "$SCRIPT_PATH" "$PASSWORD_FILE" "$LAUNCH_AGENT_PLIST" \
        "$HOME/.focus_watchdog.sh" "$HOME/Library/LaunchAgents/com.user.focuswatchdog.plist" 2>/dev/null
    gshred -u "$SCRIPT_PATH" "$PASSWORD_FILE" "$LAUNCH_AGENT_PLIST" 2>/dev/null
    launchctl unload "$LAUNCH_AGENT_PLIST" &>/dev/null
    launchctl unload "$HOME/Library/LaunchAgents/com.user.focuswatchdog.plist" &>/dev/null
    rm -f "$HOME/.focus_watchdog.sh" "$HOME/Library/LaunchAgents/com.user.focuswatchdog.plist"
    log_message "INFO" "Script and associated files deleted successfully."
    exit 0
}

monitor_backup_protection() {
    while true; do
        local flags
        local perms
        flags=$(ls -ldO "$BACKUP_DIR" | awk '{print $5}')
        perms=$(stat -f "%A" "$BACKUP_DIR")

        if [[ "$flags" != *uchg* ]] || [[ "$perms" -gt 400 ]]; then
            echo "[SECURITY] Backup folder tampering detected. Reapplying lockdown..." >> "$LOG_FILE"
            sudo chflags uchg "$BACKUP_DIR"/* 2>/dev/null
            chmod -R 400 "$BACKUP_DIR"
            echo "[SECURITY] Backup folder relocked at $(date)" >> "$LOG_FILE"
        fi
        sleep 1
    done
}

setup_watchdog() {
    local watchdog_script="${HOME}/.focus_watchdog.sh"
    local watchdog_plist="${HOME}/Library/LaunchAgents/com.user.focuswatchdog.plist"

    mkdir -p "$BACKUP_DIR"
    cp "$SCRIPT_PATH" "$BACKUP_DIR/.focus_monitor.sh"
    cp "$LAUNCH_AGENT_PLIST" "$BACKUP_DIR/com.user.focusmonitor.plist"
    cp "$PASSWORD_FILE" "$BACKUP_DIR/.focus_script_pass.enc"
    chmod -R 400 "$BACKUP_DIR"
    sudo chflags uchg "$BACKUP_DIR"/*

    cat <<EOF > "$watchdog_script"
#!/bin/bash
PLIST="$LAUNCH_AGENT_PLIST"
SCRIPT="$SCRIPT_PATH"
BACKUP_DIR="$BACKUP_DIR"

while true; do
    if [[ ! -f "\$SCRIPT" ]]; then
        cp "\$BACKUP_DIR/.focus_monitor.sh" "\$SCRIPT"
        chmod +x "\$SCRIPT"
        echo "[WATCHDOG] Script restored from backup" >> "$LOG_FILE"
    fi
    if [[ ! -f "\$PLIST" ]]; then
        cp "\$BACKUP_DIR/com.user.focusmonitor.plist" "\$PLIST"
        launchctl load "\$PLIST"
        echo "[WATCHDOG] Plist restored from backup" >> "$LOG_FILE"
    fi
    sleep 10
done
EOF

    chmod +x "$watchdog_script"

    cat <<EOF > "$watchdog_plist"
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.user.focuswatchdog</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>$watchdog_script</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
</dict>
</plist>
EOF

    launchctl load "$watchdog_plist"
    log_message "INFO" "Watchdog with backup installed and monitoring."
}

lock_backup_dir() {
    chmod -R 400 "$BACKUP_DIR"
    sudo chflags uchg "$BACKUP_DIR"/*
    chmod 500 "$SCRIPT_PATH"
    sudo chflags uchg "$SCRIPT_PATH"
    log_message "INFO" "Backup directory and script re-locked."
    echo "[SECURITY] Backup folder and script locked down again."
    exit 0
}

main() {
    validate_system

    if [[ ! -f "$PASSWORD_FILE" ]]; then
        setup_password
    fi

    case "${1:-}" in
        delete) verify_password ;;
        stop) stop_monitor ;;
        start) start_monitor ;;
        lock) lock_backup_dir ;;
    esac

    log_message "INFO" "Focus monitoring script started."

    setup_watchdog
    monitor_backup_protection &

    local sleep_time=10
    local max_sleep_time=300

    while true; do
        local jitter=$((RANDOM % 5))
        sleep $((sleep_time + jitter))

        if ! pgrep -x "$APP_NAME" > /dev/null; then
            local active_app=""
            active_app=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true')

            if [[ "$active_app" != "$EXCLUDED_APP" ]]; then
                osascript <<EOF
                tell application "System Events"
                    keystroke space using {command down}
                    delay 0.5
                    keystroke "$APP_NAME"
                    delay 0.5
                    key code 36
                end tell
EOF
                log_message "INFO" "Attempted to launch Focus."
            else
                log_message "INFO" "Zoom active; delaying launch of Focus."
            fi
        fi

        if [[ $sleep_time -lt $max_sleep_time ]]; then
            sleep_time=$((sleep_time * 2))
        fi
    done
}

trap 'log_message "ERROR" "Script encountered an unexpected error."' ERR
main "$@"
