package shiftleft.enterprise.gears_fargate.policies.validation

import data.shiftleft.lib.aws_resources.gear_resources.fargate_service_configs
import data.shiftleft.lib.violation.build_violation_details
import data.shiftleft.lib.violation.pre_check
import rego.v1

# METADATA
# title: health_check sum of (healthy_threshold * interval) + timeout must not exceed maximum
# description: The sum of (healthyThresholdCount * healthCheckIntervalSecond) + timeoutSeconds is %v at %s, which exceeds the maximum of 300.
# authors:
# - Wakanda <wakanda@xyz.com>
# custom:
#   error_code: FG926-01
violation contains build_violation_details({
  "error_code": annotation.custom.error_code,
  "message": sprintf(annotation.description, [sum,path]),
  "path": path,
  "json_path": json_path,
  "_env": service_config._env,
}) if {
  # only run rule if not disabled
  annotation := pre_check(rego.metadata.rule())

  # iterate every Fargate service + container
  some service_config in fargate_service_configs
  some con_index, container in service_config.service_definition.containers

  # pull raw value (strings) if present
  raw_healthy  := container.health_check.healthy_threshold
  raw_interval := container.health_check.interval
  raw_timeout  := container.health_check.timeout

  # If input.raw_hhealthy is present and not null convert it to number
  # apply defaults when missing
  healthy := healthyReal if {
    healthyReal := to_number(raw_healthy)
    raw_healthy != null
  }
  healthy := unhealtyDefault {
    unhealtyDefault := 10
    raw_healthy == null
  }

  interval := intervalReal {
    intervalReal := to_number(raw_interval)
    raw_interval != null
  }
  interval := intervalDefault {
    intervalDefault := 15
    raw_interval == null
  }

  timeout := timeoutReal {
    timeoutReal := to_number(raw_interval)
    raw_interval != null
  }
  timeout := timeoutDefault {
    timeoutDefault := 5
    raw_interval == null
  }

  # compute the metric and check if it exceeds the threshold.
  sum := healthy * interval + timeout
        # 10*15+5
  sum > 300

  # point at the health_check
  path       := sprintf("%s.containers[%v].health_check", [service_config.path, con_index])
  json_path  := sprintf("%s.containers[%v].health_check", [service_config.json_path, con_index])
}
