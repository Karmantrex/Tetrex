#!/bin/bash

AGENT_NAME="com.lock.timezone"
USERNAME=$(whoami)
SCRIPT_PATH="/Users/$USERNAME/lock_timezone_to_est.sh"
PLIST_PATH="/Users/$USERNAME/Library/LaunchAgents/${AGENT_NAME}.plist"
LOG_PATH="/tmp/lock_timezone.log"

start_timezone_lock() {
    echo "[*] Creating timezone enforcement script at $SCRIPT_PATH..."

    cat <<EOF > "$SCRIPT_PATH"
#!/bin/bash
DESIRED_TZ="America/New_York"
CURRENT_TZ=\$(/usr/sbin/systemsetup -gettimezone | awk '{print \$3}')
if [[ "\$CURRENT_TZ" != "\$DESIRED_TZ" ]]; then
    echo "Resetting timezone to \$DESIRED_TZ..."
    sudo /usr/sbin/systemsetup -settimezone "\$DESIRED_TZ"
else
    echo "Timezone is already correct."
fi
EOF

    chmod +x "$SCRIPT_PATH"

    echo "[*] Creating LaunchAgent at $PLIST_PATH..."

    cat <<EOF > "$PLIST_PATH"
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
"http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>${AGENT_NAME}</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>${SCRIPT_PATH}</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_PATH}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_PATH}</string>
</dict>
</plist>
EOF

    echo "[*] Loading LaunchAgent..."
    launchctl load "$PLIST_PATH"

    echo "[*] Forcing timezone to America/New_York now..."
    sudo /usr/sbin/systemsetup -settimezone "America/New_York"

    echo "[✓] Timezone lock started and will persist on startup."
}

stop_timezone_lock() {
    echo "[*] Unloading LaunchAgent..."
    launchctl unload "$PLIST_PATH" 2>/dev/null

    echo "[*] Removing script and plist..."
    rm -f "$SCRIPT_PATH" "$PLIST_PATH"

    echo "[✓] Timezone lock stopped and cleaned up."
}

case "$1" in
    start)
        start_timezone_lock
        ;;
    stop)
        stop_timezone_lock
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        ;;
esac
