@Memory <- @"MemoryUtilization_from_aws/ECS Service Metrics" {
  align Memory_avg:avg(m("MemoryUtilization"))
  make_col expression:"Memory_avg"
  aggregate MemoryUtilization_sum:sum(Memory_avg), group_by(^Service..., expression)
  topk 100
}

@CPU <- @"CPUUtilization_from_aws/ECS Service Metrics" {
  align CPU_avg:avg(m("CPUUtilization"))
  make_col expression:"CPU_avg"
  aggregate CPUUtilization_sum:sum(CPU_avg), group_by(^Service..., expression)
  topk 100
}

@DesiredTask <- @"DesiredTaskCount_from_aws/ECS Container Insights Metrics" {
  align DesiredTaskCount_max:max(m("DesiredTaskCount"))
  make_col expression:"DesiredTaskCount_max"
  aggregate DesiredTaskCount_sum:sum(DesiredTaskCount_max), group_by(^Cluster..., expression)
  topk 100
}

// Explicitly return three separate outputs
<- @Memory {}
<- @CPU {}
<- @DesiredTask {}



