violation contains build_violation_details({
	"error_code": annotation.custom.error_code,
	"message": sprintf(annotation.description, [sum, path]),
	"path": path,
	"json_path": json_path,
	"_env": service_config._env,
}) if {
	annotation := pre_check(rego.metadata.rule())
 
	some service_config in fargate_service_configs
	some con_index, container in service_config.service_definition.containers
 
	raw_healthy := container.health_check.healthy_threshold
	raw_interval := container.health_check.interval
	raw_timeout := container.health_check.timeout
 
	healthy := default_with_fallback(raw_healthy, 10)
	interval := default_with_fallback(raw_interval, 15)
	timeout := default_with_fallback(raw_timeout, 5)
 
	sum := (healthy * interval) + timeout
	sum > 300
 
	path := sprintf("%s.containers[%v].health_check", [service_config.path, con_index])
	json_path := sprintf("%s.containers[%v].health_check", [service_config.json_path, con_index])
}
 
