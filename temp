function extractUniqueURLsAboveThreshold() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getActiveSheet();          // or ss.getSheetByName("1…")
  const data = sheet.getDataRange().getValues();

  const THRESHOLD = 900;
  const uniqueURLs = new Set();

  // assume header row in row 1, so data starts at data[1]
  for (let i = 1; i < data.length; i++) {
    const desc = data[i][4];   // column E = index 4
    const url  = data[i][5];   // column F = index 5

    if (typeof desc !== 'string') continue;

    // match the number after "is " and before " in"
    const m = desc.match(/\bis\s+(\d+)\s+in\b/);
    if (m) {
      const ttu = parseInt(m[1], 10);
      if (ttu > THRESHOLD && url) {
        uniqueURLs.add(url);
      }
    }
  }

  // write results into a new (or existing) sheet
  const outName = "Above900URLs";
  let out = ss.getSheetByName(outName);
  if (!out) out = ss.insertSheet(outName);
  out.clearContents();

  const urls = Array.from(uniqueURLs).sort();
  urls.forEach((u, idx) => {
    out.getRange(idx + 1, 1).setValue(u);
  });

  // optionally write the count at the top
  out.getRange(1, 2).setValue("Count:");
  out.getRange(1, 3).setValue(urls.length);
}
