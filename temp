SELECT latest(cpu.ServiceName) AS service
FROM Metric
WHERE 
  metricName = 'aws.ecs.CPUUtilization.byService' 
  OR metricName = 'aws.ecs.MemoryUtilization.byService'
FACET aws.ecs.ServiceName
LIMIT MAX
EXCEPT
(
  SELECT latest(desired.ServiceName) AS service
  FROM Metric
  WHERE metricName = 'aws.ecs.containerinsights.DesiredTaskCount'
  FACET aws.ecs.ServiceName
  LIMIT MAX
)
