default_with_fallback(val, fallback) = out {
  out := fallback
  val == null
} else = out if {
  out := val
}

default_with_fallback(val, fallback) = out {
  out := fallback
  if val == null
} else = out {
  out := val
}


default_with_fallback(val, fallback) = out {
  not is_null(val)
  out := val
}

default_with_fallback(val, fallback) = out {
  is_null(val)
  out := fallback
}

is_null(x) {
  x == null
}
