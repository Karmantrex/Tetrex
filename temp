#!/bin/bash

check_csv() {
  local csv_string="$1"
  # Remove all properly quoted fields
  local stripped=$(echo "$csv_string" | sed 's/"[^"]*"//g')
  # Remove all commas
  local no_commas=$(echo "$stripped" | sed 's/,//g')
  # Remove whitespace
  local trimmed=$(echo "$no_commas" | tr -d '[:space:]')
  
  # If anything remains, we have improperly formatted content
  if [ -n "$trimmed" ]; then
    echo "❌ CSV contains improperly separated values"
    echo "Potential problem areas: $trimmed"
  else
    echo "✅ All values appear to be properly comma-separated"
  fi
}
