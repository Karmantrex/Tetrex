function extractUniquePipelineRows() {
  const ss       = SpreadsheetApp.getActiveSpreadsheet();
  const sheet    = ss.getActiveSheet();               // or ss.getSheetByName("YOUR_SHEET_NAME")
  const data     = sheet.getDataRange().getValues();  // includes header
  const headers  = data[0];
  const rows     = data.slice(1);

  const seen     = new Set();
  const unique   = [];

  // Collect first occurrence of each pipeline_id
  rows.forEach(row => {
    const pipelineId = row[1];  // column B → index 1
    if (pipelineId && !seen.has(pipelineId)) {
      seen.add(pipelineId);
      unique.push(row);
    }
  });

  // Prepare output sheet
  const outName = "UniquePipelines";
  let out = ss.getSheetByName(outName);
  if (!out) out = ss.insertSheet(outName);
  out.clearContents();

  // Write header + unique rows
  out.getRange(1, 1, 1, headers.length).setValues([headers]);
  if (unique.length) {
    out.getRange(2, 1, unique.length, unique[0].length).setValues(unique);
  }

  // Report count
  out.getRange(1, headers.length + 2).setValue("Unique Count:");
  out.getRange(1, headers.length + 3).setValue(unique.length);
}
